{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(cd:*)",
      "Bash(npm run:*)",
      "Bash(awk '{print $2}')",
      "Bash(xargs -I {} basename {})",
      "Bash(awk -F'AppLocales\\\\.' '{print $2}')",
      "Bash(sed 's/\\\\.tr\\(\\).*//')",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
